# Ruta absoluta al JSON de credenciales (service account o ADC exportado).
# Opcional si ya usas `gcloud auth application-default login` (el cliente usará ADC por defecto).
# Puedes guardar el JSON en credentials/ (esa carpeta está en .gitignore).
GOOGLE_APPLICATION_CREDENTIALS=credentials/gen-lang-client-0187255687-53326008621a.json

# Netlify / producción: pega aquí el JSON completo de la service account (una sola línea o multilínea según el panel).
# Si está definido, tiene prioridad sobre GOOGLE_APPLICATION_CREDENTIALS.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ID del proyecto de Google Cloud (recomendado).
GOOGLE_CLOUD_PROJECT=gen-lang-client-0187255687

# Neon PostgreSQL (connection string del dashboard; no commitear valores reales).
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# API de consola Neon (Bearer): para obtener connection URIs y leer tablas de suscriptores por proyecto.
# Clave en Neon → Account settings → API keys.
# NEON_API_KEY=
# Listar proyectos (id + nombre): npm run neon:list-projects

# JSON: una entrada por marca/proyecto Neon. `brand` debe coincidir con inferencia GA (Bodados, InstitutoAgentico, LorsClub, Lopeix, PolyNews).
# `countSql` opcional para marcas con tabla por defecto en código:
#   Bodados → public.subscribers · IDA/InstitutoAgentico → public.form_submissions · Lopeix → public.guide_subscribers · PolyNews → public.subscribers
# Otras marcas (p. ej. LorsClub) requieren `countSql` explícito.
# Ejemplo mínimo (solo projectId/role por marca; usa los SELECT anteriores automáticamente):
# NEON_SUBSCRIBER_SOURCES=[{"brand":"Bodados","projectId":"…","databaseName":"neondb","roleName":"neondb_owner"},{"brand":"InstitutoAgentico","projectId":"…","databaseName":"neondb","roleName":"…"},{"brand":"Lopeix","projectId":"…","databaseName":"neondb","roleName":"…"},{"brand":"PolyNews","projectId":"…","databaseName":"neondb","roleName":"…"}]
# Sobrescribir tabla o esquema:
# NEON_SUBSCRIBER_SOURCES=[{"brand":"PolyNews","projectId":"…","databaseName":"neondb","roleName":"…","countSql":"SELECT count(*)::int AS c FROM public.otra_tabla"}]
#
# Alternativa sin JSON: una variable por marca (mismas tablas por defecto en TypeScript).
# NEON_SUBSCRIBER_DATABASE=neondb
# NEON_SUBSCRIBER_ROLE=neondb_owner
# NEON_PROJECT_ID_BODADOS=
# NEON_PROJECT_ID_INSTITUTOAGENTICO=
# NEON_PROJECT_ID_LOPEIX=
# NEON_PROJECT_ID_POLYNEWS=
# LorsClub sin tabla por defecto: NEON_PROJECT_ID_LORSCLUB + NEON_LORSCLUB_COUNT_SQL=SELECT count(*)::int AS c FROM public.tu_tabla

# Opcional: excluir sesiones de estos User-ID en informes Data API (requiere User-ID enviado desde tus sites a GA4).
# GA4_EXCLUDED_USER_IDS=mi_user_id_interno,otro_id

# Together (POST /api/insights): misma consulta que Tráfico en la home (sin países; país y tabla detallada en /traffic).
# Destacados con TOGETHER_API_KEY en .env.local; reinicia npm run dev tras guardarla.
# Con DATABASE_URL y tablas `dashboard_insights_cache`, `dashboard_traffic_cache` y `subscriber_portfolio_daily` (ver db/schema.sql), insights, tráfico y Δ de inscritos TV se sirven desde Neon; `refresh=1` fuerza GA de nuevo.
# TOGETHER_API_KEY=
# TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Cron Netlify → POST /api/cron/insights-warmup (Authorization: Bearer …). Genera un secreto largo y configúralo también en el panel.
# CRON_SECRET=
# Periodos a precalentar (7, 30, 90, ytd): INSIGHTS_CRON_PERIODS=7,30,90,ytd
# Origen: both | live | stored — INSIGHTS_CRON_SOURCES=both
#
# Botón ⚡ (precalentar IA) en el panel → POST /api/insights/warmup. En producción: ALLOW_DASHBOARD_INSIGHTS_WARMUP=1 en Netlify; en npm run dev no hace falta.
# ALLOW_DASHBOARD_INSIGHTS_WARMUP=1

# Netlify Identity: en producción (Netlify) el panel pide login. En `npm run dev` NO pide contraseña por defecto.
# Para probar el widget en local: NEXT_PUBLIC_FORCE_NETLIFY_AUTH=1 y NEXT_PUBLIC_NETLIFY_SITE_URL=https://tu-site.netlify.app
# Forzar sin login también en build preview (opcional): NEXT_PUBLIC_SKIP_NETLIFY_AUTH=1
# Site: https://metrics-ga4-tv.netlify.app · Admin: https://app.netlify.com/projects/metrics-ga4-tv
#
# En Netlify → Site configuration → Environment variables (Production), replica las claves que uses en .env.local
# para las API routes: GOOGLE_APPLICATION_CREDENTIALS (o pega el JSON en una var y carga en código), GOOGLE_CLOUD_PROJECT,
# DATABASE_URL, TOGETHER_API_KEY, NEON_API_KEY, NEON_SUBSCRIBER_SOURCES, GA4_EXCLUDED_USER_IDS, CRON_SECRET, etc.
